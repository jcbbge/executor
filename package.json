{
  "name": "executor-v2",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "catalog": {
    "@effect/platform": "^0.93.6",
    "@effect/vitest": "^0.27.0",
    "@types/node": "^20.19.9",
    "effect": "^3.19.8",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "prepare": "effect-language-service patch",
    "dev": "turbo run dev --parallel",
    "typecheck": "turbo run typecheck",
    "knip": "bunx knip --config knip.json",
    "db:wipe": "python3 -c \"import zipfile; zipfile.ZipFile('/tmp/_convex_empty.zip','w').close()\" && cd apps/convex && npx convex import --replace-all --yes /tmp/_convex_empty.zip"
  },
  "devDependencies": {
    "@effect/language-service": "^0.76.0",
    "@types/bun": "^1.2.22",
    "@types/node": "catalog:",
    "turbo": "^2.8.11",
    "typescript": "catalog:"
  },
  "dependencies": {
    "convex": "^1.32.0",
    "vercel": "^50.23.2"
  }
}
